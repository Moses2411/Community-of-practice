# ABU CoP Research Platform — Environment Configuration
# Copy this file to .env and customize values.

# Security — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-secret-in-production

# Database — defaults to SQLite. For production, use PostgreSQL:
# DATABASE_URL=postgresql://user:password@host:5432/dbname
# DATABASE_URL=sqlite:///cop_research_platform.db

# Token lifetime in minutes (default: 7 days)
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Quiz — number of questions per randomized practice round
QUIZ_ROUND_SIZE=7

# CORS — comma-separated allowed origins. Use "*" for all (default).
CORS_ORIGINS=*

# Seed — default researcher credentials (created on first startup)
# SEED_RESEARCHER_EMAIL=researcher@abuzaria.edu.ng
# SEED_RESEARCHER_PASSWORD=Research@12345
